for ip in $(cat /home/ubuntu/hadoop/etc/hadoop/workers); do
    echo "--- Subiendo datos desde el nodo: $ip ---"
    ssh -o StrictHostKeyChecking=no $ip "/home/ubuntu/hadoop/bin/hdfs dfs -put /home/ubuntu/onpe_*.jsonl /onpe/raw/"
done

